{
  // Lenient config for the org profile repo — keep structural checks only.
  "config": {
    "default": true,
    "MD013": false, // line length
    "MD022": false, // blanks around headings
    "MD024": false, // duplicate heading text
    "MD032": false, // blanks around lists
    "MD033": false, // inline HTML
    "MD034": false, // bare URLs
    "MD041": false, // first line must be a top-level heading
    "MD060": false  // table pipe spacing style
  },
  "globs": ["**/*.md"]
}
